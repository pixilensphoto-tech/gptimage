# Azure Foundry - GPT Image 2 Model
FOUNDRY_OPENAI_ENDPOINT=https://your-foundry-endpoint.cognitiveservices.azure.com/
FOUNDRY_OPENAI_API_KEY=your-foundry-api-key
FOUNDRY_OPENAI_DEPLOYMENT=gpt-image-2
FOUNDRY_OPENAI_API_VERSION=2025-04-01-preview

# Codex API (Azure Foundry Codex Image API)
CODEX_API_URL=https://codeximageapi-az.pixilens.online
CODEX_API_KEY=replace-with-codex-api-key

# Optional: Original Azure OpenAI (for reference analysis via Vision)
AZURE_OPENAI_ENDPOINT=https://dasr-mm9xqd8v-eastus2.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-image-2
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_API_KEY=replace-with-coolify-secret
AZURE_OPENAI_VISION_DEPLOYMENT=your-vision-deployment
AZURE_OPENAI_VISION_API_VERSION=2025-01-01-preview

# Image limits
MAX_UPLOAD_MB=8
MAX_REFERENCE_IMAGES=6
GENERATION_RATE_LIMIT_PER_MINUTE=8
AZURE_IMAGE_MIN_REQUEST_SPACING_MS=6500

# JSON API Key (for v1 endpoints)
GPTIMAGE_API_KEY=replace-with-your-json-api-key
